generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Una sola fila en v1; el esquema no impide multiusuario futuro.
model User {
  id        String   @id @default(cuid())
  name      String
  xp        Int      @default(0)
  coins     Int      @default(0)
  createdAt DateTime @default(now())
}

// status: ACTIVE | COMPLETED | ARCHIVED
model LongTermGoal {
  id             String          @id @default(cuid())
  title          String
  description    String?
  icon           String?
  targetDate     DateTime?
  status         String          @default("ACTIVE")
  completedAt    DateTime? // fecha de "Conseguido" (vitrina de trofeos)
  createdAt      DateTime        @default(now())
  weeklyGoals    WeeklyGoal[]
  recurringGoals RecurringGoal[]
}

model Week {
  id          String       @id @default(cuid())
  startDate   DateTime // lunes 00:00 (hora local del servidor)
  endDate     DateTime // domingo 23:59:59.999
  closedAt    DateTime?
  penaltyMsg  String? // mensaje duro elegido al cierre; null si semana limpia
  msgSeen     Boolean      @default(false)
  summarySeen Boolean      @default(false) // resumen "Wrapped" ya descartado
  weeklyGoals WeeklyGoal[]
  tasks       Task[]
}

// status: ACTIVE | COMPLETED | FAILED (FAILED se asigna al cierre de semana)
model WeeklyGoal {
  id                String         @id @default(cuid())
  weekId            String
  week              Week           @relation(fields: [weekId], references: [id], onDelete: Cascade)
  longTermGoalId    String?
  longTermGoal      LongTermGoal?  @relation(fields: [longTermGoalId], references: [id], onDelete: SetNull)
  title             String
  isCritical        Boolean        @default(false)
  status            String         @default("ACTIVE")
  targetDays        Int? // hábito: meta de días/semana (1-7); null = objetivo normal
  habitDifficulty   String? // EASY | MEDIUM | HARD del check diario del hábito
  isGym             Boolean        @default(false) // hábito de entrenamiento (enlaza con /gym)
  sourceRecurringId String? // plantilla origen: idempotencia al instanciar
  sourceRecurring   RecurringGoal? @relation(fields: [sourceRecurringId], references: [id], onDelete: SetNull)
  tasks             Task[]
}

// difficulty: EASY | MEDIUM | HARD
model Task {
  id                String         @id @default(cuid())
  weekId            String
  week              Week           @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weeklyGoalId      String?
  weeklyGoal        WeeklyGoal?    @relation(fields: [weeklyGoalId], references: [id], onDelete: SetNull)
  title             String
  dueDay            Int? // 0-6 (lunes-domingo), null = cualquier día
  difficulty        String         @default("MEDIUM")
  sourceRecurringId String? // plantilla origen: idempotencia al instanciar
  sourceRecurring   RecurringTask? @relation(fields: [sourceRecurringId], references: [id], onDelete: SetNull)
  xpReward          Int
  coinReward        Int
  completedAt       DateTime?
}

model Reward {
  id          String       @id @default(cuid())
  title       String
  icon        String?
  cost        Int
  active      Boolean      @default(true)
  redemptions Redemption[]
}

model Redemption {
  id         String   @id @default(cuid())
  rewardId   String
  reward     Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  cost       Int // coste en el momento del canje
  redeemedAt DateTime @default(now())
}

// Ledger auditable de todo movimiento de XP/monedas.
// reason: TASK_COMPLETED | TASK_UNCOMPLETED | GOAL_COMPLETED | PENALTY
//       | REDEMPTION | LOOT | PERFECT_DAY
// LOOT (refId=task): botín variable al completar. PERFECT_DAY
// (refId=`perfect:<weekId>:<día>`): bonus por completar el día; su reverso al
// desmarcar es otro asiento PERFECT_DAY negativo con el mismo refId.
model PointsEntry {
  id        String   @id @default(cuid())
  xpDelta   Int      @default(0)
  coinDelta Int      @default(0)
  reason    String
  refId     String?
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// Plantilla de objetivo semanal recurrente. Nunca se muestra como trabajo
// pendiente: cada semana nueva se instancia como WeeklyGoal normal.
// active=false = en pausa (no se instancia, las instancias pasadas quedan).
model RecurringGoal {
  id              String          @id @default(cuid())
  title           String
  isCritical      Boolean         @default(false)
  longTermGoalId  String?
  longTermGoal    LongTermGoal?   @relation(fields: [longTermGoalId], references: [id], onDelete: SetNull)
  targetDays      Int? // hábito: meta de días/semana (1-7); null = objetivo normal
  habitDifficulty String? // EASY | MEDIUM | HARD del check diario del hábito
  isGym           Boolean         @default(false) // hábito de entrenamiento (enlaza con /gym)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  tasks           RecurringTask[]
  instances       WeeklyGoal[]
}

// Catálogo de ejercicios del usuario. Sin borrado: archivar preserva el
// historial (archived=true solo lo saca del formulario de registro).
model Exercise {
  id          String     @id @default(cuid())
  name        String
  muscleGroup String? // texto libre: bloque de rutina ("Torso A") o grupo muscular
  targetSets  Int? // objetivo de la rutina: series…
  targetReps  String? // …y reps ("6-8", "20-30 seg"); precargan el registro
  archived    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  entries     GymEntry[]
}

// Registro de gym: una fila por ejercicio y sesión (series a distinto peso =
// varias filas). Tracking puro: sin relación con Task ni con el ledger.
model GymEntry {
  id         String   @id @default(cuid())
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  date       DateTime // día de la sesión, 00:00 hora local
  sets       Int
  reps       Int
  weightKg   Float? // null = peso corporal
  note       String?
  createdAt  DateTime @default(now())
}

// Plantilla de tarea. recurringGoalId null = tarea suelta recurrente.
// active solo se gestiona en sueltas; en tareas de objetivo se borra en su lugar.
model RecurringTask {
  id              String         @id @default(cuid())
  recurringGoalId String?
  recurringGoal   RecurringGoal? @relation(fields: [recurringGoalId], references: [id], onDelete: Cascade)
  title           String
  dueDay          Int? // 0-6 (lunes-domingo), null = cualquier día
  difficulty      String         @default("MEDIUM")
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  instances       Task[]
}
